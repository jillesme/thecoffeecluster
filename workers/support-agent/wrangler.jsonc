{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "the-coffee-cluster-support-agent",
  "compatibility_date": "2026-06-23",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  },
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true
    }
  ],
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      // Local dev: set CLOUDFLARE_HYPERDRIVE_LOCAL_CONNECTION_STRING_HYPERDRIVE
      // in workers/support-agent/.dev.vars instead of committing credentials here.
      "id": "d3a2db789ace440eb99d93e8d7fb88c9"
    }
  ],
  "placement": {
    "region": "aws:eu-central-1"
  },
  "vars": {
    "SUPPORT_FROM_EMAIL": "support@thecoffeecluster.com",
    "SUPPORT_ESCALATION_EMAIL": "support@thecoffeecluster.com",
    "SUPPORT_EMAIL_DRY_RUN": "true",
    "SUPPORT_AGENT_ENABLED": "false"
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["FlueRegistry", "FlueCoffeeSupportAgent"]
    }
  ]
}
