		"drizzle-orm": "^0.45.2",
		"js-cookie": "^3.0.8",
		"lucide-react": "^0.575.0",
		"next": "15.5.10",
		"next-themes": "^0.4.6",
		"pg": "^8.21.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
